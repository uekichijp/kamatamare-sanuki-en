---
import { navigation } from "../data/navigation";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <nav aria-label="Footer navigation">
      <ul class="footer-nav">
        {navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>
    <p class="site-footer__notice">
      This is an independent, unofficial guide and is not affiliated with Kamatamare Sanuki.
    </p>
    <p class="site-footer__copyright">&copy; {year} Kamatamare Sanuki English Guide</p>
  </div>
</footer>
